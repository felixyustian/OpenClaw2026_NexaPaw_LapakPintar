# ─── Qwen / DashScope ───────────────────────────────────────────────────────
QWEN_API_KEY=your_dashscope_api_key_here
QWEN_MODEL=qwen3-14b

# ─── DOKU Payment ────────────────────────────────────────────────────────────
DOKU_CLIENT_ID=your_doku_client_id
DOKU_SECRET_KEY=your_doku_secret_key
DOKU_BASE_URL=https://api.doku.com

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ─── FastAPI ─────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# ─── ChromaDB (RAG) ──────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ─── Scheduler ───────────────────────────────────────────────────────────────
PANTAU_INTERVAL_MINUTES=30
LAPORAN_HOUR=23
LAPORAN_MINUTE=0

# ─── Demo Mode ───────────────────────────────────────────────────────────────
DEMO_MODE=false
